# Postgres (Neon works well for Vercel deployments)
DATABASE_URL="postgresql://postgres:dev@localhost:5432/mike_archive"

# Admin access. Generate the hash with: npm run admin:hash-password -- "your password"
ADMIN_PASSWORD_HASH="scrypt$..."
# Plaintext is accepted for local migration only. Do not use it in production.
# ADMIN_PASSWORD="change-me"
# Generate with: openssl rand -base64 32
SESSION_SECRET="replace-with-at-least-32-random-characters"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_ALLOWED_COUNTRIES="US"

# Vercel Blob. Connected Vercel projects can use OIDC automatically.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Server URL used for Stripe redirects. Never trust a request Host header in production.
APP_URL="http://localhost:3000"

# Public shop settings — all optional
NEXT_PUBLIC_SHOP_NAME="Mike's store"
NEXT_PUBLIC_SHOP_OWNER="Mike"
NEXT_PUBLIC_SHOP_LOCATION="Los Angeles, CA"
NEXT_PUBLIC_SHOP_EMAIL=""
NEXT_PUBLIC_INSTAGRAM_URL=""
# Flat shipping fee in the smallest currency unit. 800 = $8.00; 0 = free.
NEXT_PUBLIC_SHIPPING_CENTS="0"
# Keep this factual. Add handling time only after Mike confirms it.
NEXT_PUBLIC_SHIPPING_NOTE="Ships within the United States."
NEXT_PUBLIC_CURRENCY="usd"
NEXT_PUBLIC_LOCALE="en-US"
