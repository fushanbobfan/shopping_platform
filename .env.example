# Database
DATABASE_URL="postgresql://postgres:dev@localhost:5432/postgres"

# Admin login (single seller)
ADMIN_PASSWORD="change-me"
# openssl rand -base64 32
SESSION_SECRET="replace-with-32-byte-base64-secret-at-least-32-chars"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Vercel Blob (for product image uploads)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Public base URL (used in Stripe redirect URLs)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: currency & allowed shipping countries (comma-separated ISO codes)
NEXT_PUBLIC_CURRENCY="usd"
STRIPE_ALLOWED_COUNTRIES="US,CA,GB,AU,JP,SG,HK,CN"
