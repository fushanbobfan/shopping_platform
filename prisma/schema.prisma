generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductStatus {
  AVAILABLE
  RESERVED
  SOLD
  HIDDEN
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  CANCELLED
  EXPIRED
  REFUNDED
}

model Product {
  id                String         @id @default(cuid())
  slug              String         @unique
  name              String
  brand             String?
  description       String
  story             String?
  priceCents        Int
  compareAtCents    Int?
  currency          String         @default("usd")
  size              String?
  category          String?
  condition         String?
  color             String?
  material          String?
  measurements      Json?
  featured          Boolean        @default(false)
  status            ProductStatus  @default(AVAILABLE)
  reservedUntil     DateTime?
  reservedByOrderId String?
  reservedByOrder   Order?         @relation("ActiveReservation", fields: [reservedByOrderId], references: [id], onDelete: SetNull)
  images            ProductImage[]
  orderItems        OrderItem[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([status, createdAt])
  @@index([featured, status])
  @@index([reservedByOrderId])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  alt       String?
  order     Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, order])
}

model Order {
  id               String      @id @default(cuid())
  publicId         String      @unique
  stripeSessionId  String?     @unique
  status           OrderStatus @default(PENDING)
  buyerEmail       String?
  buyerName        String?
  shippingLine1    String?
  shippingLine2    String?
  shippingCity     String?
  shippingState    String?
  shippingPostal   String?
  shippingCountry  String?
  shippingCents    Int         @default(0)
  totalCents       Int
  currency         String
  carrier          String?
  trackingNumber   String?
  items            OrderItem[]
  reservedProducts Product[]   @relation("ActiveReservation")
  expiresAt        DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  paidAt           DateTime?
  shippedAt        DateTime?

  @@index([status, createdAt])
  @@index([expiresAt])
}

model OrderItem {
  id              String  @id @default(cuid())
  orderId         String
  productId       String
  nameAtPurchase  String
  imageAtPurchase String?
  priceAtPurchase Int
  quantity        Int     @default(1)
  order           Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product @relation(fields: [productId], references: [id])

  @@unique([orderId, productId])
  @@index([productId])
}

model StripeEvent {
  id        String   @id
  type      String
  createdAt DateTime @default(now())
}

model AdminLoginAttempt {
  fingerprint String    @id
  failures    Int       @default(0)
  windowStart DateTime  @default(now())
  lockedUntil DateTime?
  updatedAt   DateTime  @updatedAt
}
